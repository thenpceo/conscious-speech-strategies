# Stripe API Keys — copy this file to .env.local and fill in your values
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# Get this from Stripe Dashboard > Products > MBS Camp > Price ID
STRIPE_PRICE_ID=price_your_price_id_here

# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Twilio SMS — get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Anthropic Claude API — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Site URL — used for Twilio webhook signature validation
NEXT_PUBLIC_SITE_URL=https://your-domain.com
